DATABASE_URL="postgresql://postgres:postgres@localhost:5432/base_account"

AUTH_ISSUER="http://localhost:3000"
AUTH_AUDIENCE="base-account-client"
AUTH_JWT_KID="auth-key-1"
AUTH_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----"
AUTH_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"
AUTH_HASH_PEPPER="change-this-in-production"
# Production MUST set this (recommended: .stringzhao.life) so sibling subdomains
# can refresh session via shared refresh_token cookie.
AUTH_COOKIE_DOMAIN=""

ACCESS_TOKEN_EXPIRES_IN_SEC="900"
REFRESH_TOKEN_EXPIRES_IN_SEC="2592000"
EMAIL_CODE_TTL_SEC="600"
EMAIL_CODE_COOLDOWN_SEC="60"
EMAIL_CODE_MAX_ATTEMPTS="5"

RESEND_API_KEY=""
RESEND_FROM_EMAIL="Base Account <auth@yourdomain.com>"
ADMIN_EMAILS="admin@yourdomain.com"
