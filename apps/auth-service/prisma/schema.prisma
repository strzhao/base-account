generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum EmailCodePurpose {
  LOGIN
}

enum ActorType {
  SYSTEM
  ADMIN
  USER
}

enum ServiceIconMode {
  FAVICON
  CUSTOM
  GENERATED
}

enum InvitationCodeStatus {
  ACTIVE
  REDEEMED
  REVOKED
}

model User {
  id          String      @id @default(cuid())
  email       String      @unique
  status      UserStatus  @default(ACTIVE)
  lastLoginAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  sessions    Session[]
  consents    ServiceConsent[]
  createdInvitations  InvitationCode[] @relation("createdInvitations")
  redeemedInvitations InvitationCode[] @relation("redeemedInvitations")

  @@index([status])
}

model EmailCode {
  id           String           @id @default(cuid())
  requestId    String           @unique
  email        String
  codeHash     String
  purpose      EmailCodePurpose
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int              @default(0)
  createdAt    DateTime         @default(now())

  @@index([email, purpose, createdAt])
  @@index([expiresAt])
}

model Session {
  id                       String    @id @default(cuid())
  userId                   String
  refreshTokenHash         String    @unique
  previousRefreshTokenHash String?
  rotatedAt                DateTime?
  expiresAt                DateTime
  revokedAt                DateTime?
  userAgent                String?
  ip                       String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([previousRefreshTokenHash])
}

model ServiceConsent {
  id        String   @id @default(cuid())
  userId    String
  serviceId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
  @@index([serviceId])
}

model AuthServiceApp {
  id             String          @id @default(cuid())
  serviceKey     String          @unique
  displayName    String
  origin         String          @unique
  hostname       String
  iconUrl        String?
  iconMode       ServiceIconMode @default(FAVICON)
  consentSummary String
  enabled        Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([enabled, updatedAt])
  @@index([hostname])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorType  ActorType
  actorId    String?
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([action, createdAt])
  @@index([targetType, targetId])
}

model InvitationCode {
  id         String               @id @default(cuid())
  code       String               @unique
  serviceKey String
  creatorId  String
  status     InvitationCodeStatus @default(ACTIVE)
  redeemedBy String?
  redeemedAt DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  creator    User                 @relation("createdInvitations", fields: [creatorId], references: [id], onDelete: Cascade)
  redeemer   User?                @relation("redeemedInvitations", fields: [redeemedBy], references: [id], onDelete: SetNull)

  @@index([serviceKey, creatorId])
  @@index([serviceKey, status])
  @@index([redeemedBy])
}

model JwkKey {
  id                  String   @id @default(cuid())
  kid                 String   @unique
  publicJwk           Json
  privateKeyEncrypted String
  status              String
  createdAt           DateTime @default(now())
}
